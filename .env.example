# EvolveLab Environment Configuration
# Copy to .env and adjust as needed

# Evolution Parameters
POPULATION_SIZE=8
MAX_GENERATIONS=20
ELITE_COUNT=2
TOURNAMENT_SIZE=3

# Fitness Weights
ACCURACY_WEIGHT=0.7
COST_WEIGHT=0.3

# Database
DATABASE_URL=sqlite:///evolvelab.db

# Server
API_HOST=0.0.0.0
API_PORT=8000

# Optional: Ollama integration (leave empty to use rule-based agents)
OLLAMA_BASE_URL=
OLLAMA_MODEL=
